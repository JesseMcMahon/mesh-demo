# Development environment — loaded by Expo when running `npx expo start`
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_SOCKET_URL=http://localhost:3001
EXPO_PUBLIC_ENABLE_MATCHUP_CENTER_V2=true
EXPO_PUBLIC_MATCHUP_CENTER_POLL_MS=15000

EXPO_PUBLIC_API_TIMEOUT_MS=14000
EXPO_PUBLIC_ENABLE_GOOGLE_LOCATION_AUTOCOMPLETE=true
EXPO_PUBLIC_LOCATION_AUTOCOMPLETE_MIN_CHARS=3
EXPO_PUBLIC_LOCATION_AUTOCOMPLETE_DEBOUNCE_CITY_MS=400
EXPO_PUBLIC_LOCATION_AUTOCOMPLETE_DEBOUNCE_STREET_MS=500
EXPO_PUBLIC_LOCATION_AUTOCOMPLETE_CACHE_TTL_MS=300000
EXPO_PUBLIC_LOCATION_SESSION_IDLE_MS=180000
