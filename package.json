{
  "name": "mesh-demo",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "smoke:draft-room": "node ./scripts/smoke-draft-room.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "postinstall": "patch-package",
    "start:demo": "EXPO_PUBLIC_APP_MODE=investor_demo expo start",
    "start:demo:devclient": "EXPO_PUBLIC_APP_MODE=investor_demo npx expo start --dev-client -c",
    "pods:sync": "env -u GEM_HOME -u GEM_PATH -u RUBYOPT PATH=/opt/homebrew/opt/ruby/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin npx pod-install",
    "ios:demo": "env -u GEM_HOME -u GEM_PATH -u RUBYOPT PATH=/opt/homebrew/opt/ruby/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin EXPO_PUBLIC_APP_MODE=investor_demo npx expo run:ios -d \"iPhone 16 Pro\"",
    "build:ios:demo": "eas build -p ios --profile investor-demo",
    "submit:ios:demo": "eas submit -p ios --profile investor-demo --latest"
  },
  "dependencies": {
    "@azesmway/react-native-unity": "^1.0.11",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.5.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.90.12",
    "better-auth": "^1.4.5",
    "expo": "~54.0.23",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.10",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-image": "~3.0.10",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.8",
    "expo-location": "^19.0.8",
    "expo-notifications": "~0.32.13",
    "expo-router": "~6.0.14",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "expo-symbols": "~1.0.7",
    "expo-system-ui": "~6.0.8",
    "expo-web-browser": "~15.0.9",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-date-picker": "^5.0.13",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "socket.io-client": "^4.7.5"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/react-native": "^0.72.8",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.0",
    "tailwindcss": "^3.4.18",
    "typescript": "~5.9.2"
  },
  "private": true
}
